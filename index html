<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Romantic Love App</title>
<style>
/* Reset */
*{margin:0;padding:0;box-sizing:border-box;font-family:'Arial', sans-serif;}
body,html{width:100%;height:100%;overflow:hidden;background:#0b0c10;color:#fff;position:relative;}

/* Glowing background */
body::before{
  content:"";
  position:absolute;width:200%;height:200%;
  background: radial-gradient(circle at 30% 30%, #ff4d6d, transparent 60%), radial-gradient(circle at 70% 70%, #ff99cc, transparent 60%);
  animation:bgMove 20s linear infinite;
  z-index:-2;
}
@keyframes bgMove{0%{transform:translate(0,0);}50%{transform:translate(-50px,50px);}100%{transform:translate(0,0);}}

/* Stars */
.star{position:absolute;width:2px;height:2px;background:#fff;border-radius:50%;opacity:0.8;animation:twinkle 3s infinite alternate;}
@keyframes twinkle{0%{opacity:0.2;}100%{opacity:1;}}

/* Hearts */
.heart{position:absolute;width:20px;height:20px;background:red;transform:rotate(45deg);animation:floatHeart linear infinite;}
.heart::before,.heart::after{content:"";position:absolute;width:20px;height:20px;background:red;border-radius:50%;}
.heart::before{top:-10px;left:0;} .heart::after{left:-10px;top:0;}
@keyframes floatHeart{0%{transform:translateY(100vh) rotate(45deg);opacity:1;}100%{transform:translateY(-10vh) rotate(45deg);opacity:0;}}

/* Lock Screen */
#lockScreen{
  position:absolute;top:0;left:0;width:100%;height:100%;
  display:flex;justify-content:center;align-items:center;flex-direction:column;
  background: linear-gradient(135deg,#ff4d6d,#ff99cc);transition:opacity 0.5s;
}
#lockScreen input{padding:12px 20px;border:none;border-radius:30px;font-size:18px;margin-top:20px;outline:none;}
#lockScreen button{margin-top:15px;padding:12px 25px;border:none;border-radius:30px;background:#fff;color:#ff4d6d;font-weight:bold;cursor:pointer;transition:0.3s;}
#lockScreen button:hover{transform:scale(1.05);}

/* Pages */
.page{width:100%;height:100%;display:none;padding:20px;overflow-y:auto;position:absolute;top:0;left:0;background: linear-gradient(to top, #0b0c10, #1c1c1c);transition:opacity 0.5s, transform 0.5s;}
.page.active{display:block;opacity:1;transform:translateX(0);}
.page.fade-out{opacity:0;transform:translateX(-100%);}

/* Typing text */
.typing{
  border-right: 2px solid #fff;
  white-space: pre-wrap;overflow-wrap: break-word;
  max-width:400px;font-size:22px;margin-bottom:20px;min-height:100px;
  color:#ffdde1;text-shadow:0 0 5px #ff99cc;
}

/* Arrows */
.arrow{
  position:absolute;top:50%;transform:translateY(-50%);
  font-size:50px;cursor:pointer;opacity:0;transition:0.5s;
  color:#ff4d6d;text-shadow:0 0 10px #ff99cc;
}
.arrow.show{opacity:1;animation:pulse 1.5s infinite;}
@keyframes pulse{0%{transform:translateY(-50%) scale(1);}50%{transform:translateY(-50%) scale(1.1);}100%{transform:translateY(-50%) scale(1);}}
.arrow-left{left:10px;}
.arrow-right{right:10px;}

/* Memories */
.memories button{display:block;margin:12px 0;padding:12px 20px;border:none;border-radius:30px;background:#ff4d6d;color:#fff;font-weight:bold;cursor:pointer;transition:0.3s;box-shadow:0 0 10px #ff99cc;}
.memories button:hover{transform:scale(1.05);}
.memory-card{margin-top:15px;padding:15px;border-radius:25px;background:rgba(255,77,109,0.2);color:#fff;text-align:center;box-shadow:0 0 10px #ff99cc;opacity:0;transition:opacity 0.5s;}
.memory-card.show{opacity:1;}
.timer{margin-top:20px;font-size:18px;color:#ff99cc;text-shadow:0 0 5px #ff4d6d;}

/* Responsive */
@media(max-width:500px){.typing{font-size:18px;} .arrow{font-size:40px;}}
</style>
</head>
<body>

<!-- Stars & Hearts -->
<script>
for(let i=0;i<120;i++){let star=document.createElement('div');star.className='star';
star.style.top=Math.random()*100+'%';star.style.left=Math.random()*100+'%';
star.style.width=Math.random()*3+1+'px';star.style.height=star.style.width;
star.style.animationDuration=(Math.random()*3+2)+'s';document.body.appendChild(star);}
for(let i=0;i<25;i++){let heart=document.createElement('div');heart.className='heart';
heart.style.left=Math.random()*100+'%';heart.style.animationDuration=(4+Math.random()*4)+'s';
document.body.appendChild(heart);}
</script>

<!-- Lock Screen -->
<div id="lockScreen">
  <h2 style="text-shadow:0 0 10px #fff;">Enter Secret Code</h2>
  <input type="password" id="codeInput" placeholder="Enter code">
  <button onclick="checkCode()">Unlock</button>
  <p id="wrong" style="color:#fff;margin-top:10px;"></p>
</div>

<!-- Story Page -->
<div id="storyPage" class="page">
  <div class="typing" id="storyText"></div>
  <div class="arrow arrow-right" id="toMemories">&#8594;</div>
</div>

<!-- Memories Page -->
<div id="memoriesPage" class="page memories">
  <h2 style="text-align:center;color:#ffdde1;text-shadow:0 0 10px #ff4d6d;">Our Memories</h2>
  <button onclick="showMemory('firstHoldHand')">First Hold Hand</button>
  <button onclick="showMemory('firstKiss')">First Kiss</button>
  <button onclick="showMemory('firstHug')">First Hug</button>
  <button onclick="showMemory('firstLipKiss')">First Lip Kiss</button>
  <div class="memory-card" id="memoryText"></div>
  <div class="timer" id="relationshipTimer"></div>
  <div class="arrow arrow-left" id="toStory">&#8592;</div>
</div>

<script>
const secretCode="2905";
const lockScreen=document.getElementById('lockScreen');
const storyPage=document.getElementById('storyPage');
const memoriesPage=document.getElementById('memoriesPage');
const storyText=document.getElementById('storyText');

function checkCode(){
  const input=document.getElementById('codeInput').value;
  if(input===secretCode){
    lockScreen.style.opacity=0;
    setTimeout(()=>{lockScreen.style.display='none';storyPage.classList.add('active');},500);
    // Romantic Story Text
    showTyping(storyText, 
      "From the moment our eyes met, the stars themselves danced for us. 🌌\n"+
      "Every heartbeat whispers your name, every night sky glows with our love. 💖\n"+
      "I remember our first hug, our first kiss… each moment is a galaxy in my heart. 💫\n"+
      "Our first hand hold, so gentle, so magical, sealed our hearts together. 🤝\n"+
      "With you, every day feels like magic, every second a lifetime of love. ❤️"
    );
    setTimeout(()=>{document.getElementById('toMemories').classList.add('show');},1000);
  } else {
    document.getElementById('wrong').innerText='Wrong code! Try again.';
  }
}

// Typing animation with natural pauses
function showTyping(element,text,speed=50){
  element.innerText='';let i=0;
  function type(){
    element.innerText+=text.charAt(i);i++;
    if(i<text.length){
      let delay=(text.charAt(i-1)=='.'||text.charAt(i-1)=='!'||text.charAt(i-1)=='…')? speed*6 : speed + Math.random()*30;
      setTimeout(type,delay);
    }
  } type();
}

// Navigation
document.getElementById('toMemories').addEventListener('click', ()=>{
  storyPage.classList.remove('active');memoriesPage.classList.add('active');
  setTimeout(()=>{document.getElementById('toStory').classList.add('show');},500);
});
document.getElementById('toStory').addEventListener('click', ()=>{
  memoriesPage.classList.remove('active');storyPage.classList.add('active');
});

// Memories
const memories={
  firstHoldHand:"Our first hand hold: 7 juin 2025",
  firstKiss:"Our first kiss: 28 juin 2025",
  firstHug:"Our first hug: 28 juin 2025",
  firstLipKiss:"Our first lip kiss: 16 juil. 2025"
};
function showMemory(type){
  const card=document.getElementById('memoryText');
  card.innerText=memories[type];
  card.classList.remove('show');
  setTimeout(()=>{card.classList.add('show');},50);
}

// Relationship Timer
const startDate=new Date("2025-05-29T18:26:30");
function updateTimer(){
  const now=new Date();let diff=now-startDate;
  let days=Math.floor(diff/1000/60/60/24);
  let hours=Math.floor(diff/1000/60/60)%24;
  let minutes=Math.floor(diff/1000/60)%60;
  let seconds=Math.floor(diff/1000)%60;
  document.getElementById('relationshipTimer').innerText=
    `Together for ${days}d ${hours}h ${minutes}m ${seconds}s`;
}
setInterval(updateTimer,1000);updateTimer();
</script>
</body>
</html>
